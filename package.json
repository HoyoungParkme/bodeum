{
  "name": "bodeum",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "frontend:dev": "corepack pnpm --dir frontend/web dev",
    "frontend:build": "corepack pnpm --dir frontend/web build",
    "frontend:typecheck": "corepack pnpm --dir frontend/web exec tsc -p tsconfig.json --noEmit",
    "docker:up": "docker compose -f infrastructure/docker/compose.yml up --build",
    "docker:down": "docker compose -f infrastructure/docker/compose.yml down",
    "docker:up:dev": "docker compose -f infrastructure/docker/compose.dev.yml up --build",
    "docker:down:dev": "docker compose -f infrastructure/docker/compose.dev.yml down"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
